{
  "$schema": "./endpoints.schema.json",
  "project": "road-trip-tests",
  "environments": {
    "dev": {
      "literalEndpoint": {
        "source": "literal",
        "value": "https://literal.example.com",
        "description": "Test literal endpoint"
      },
      "envEndpoint": {
        "source": "env",
        "key": "TEST_ENV_VAR",
        "description": "Test environment variable endpoint"
      },
      "compound": {
        "baseUrl": { "source": "literal", "value": "https://api.example.com" },
        "apiKey": { "source": "env", "key": "TEST_API_KEY" },
        "description": "Test compound endpoint"
      }
    },
    "prod": {
      "keyvaultEndpoint": {
        "source": "keyvault",
        "vault": "kv-test-prod",
        "secret": "TestSecret",
        "description": "Test keyvault endpoint"
      },
      "literalProd": {
        "source": "literal",
        "value": "https://prod.example.com",
        "description": "Test literal in prod"
      }
    }
  }
}
