{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Blob": {
    "UseDevelopmentStorage": false
  },
  "Upload": {
    "SasTokenTtl": "02:00:00",
    "MaxBlockSizeBytes": 4194304
  },
  "OrphanSweeper": {
    "IntervalHours": 1,
    "StaleThresholdHours": 48
  },
  "ClientProtocol": {
    "MinVersion": "1.0.0"
  }
}
